# ── Shared ──────────────────────────────────────────────────────────────
# LLM Wiki workspace root (used by both connectors)
# OUTPUT_DIR=/path/to/your/knowledge-base

# ── Fathom ──────────────────────────────────────────────────────────────
# Required for Fathom connector: API key (Settings > API Access on fathom.video)
FATHOM_API_KEY=

# Optional Fathom overrides
# FATHOM_BASE_URL=https://api.fathom.ai/external/v1
# FATHOM_OUTPUT_SUBDIR=Fathom Transcripts
# FATHOM_STATE_FILE=.fathom-export-state.json
# RATE_LIMIT_PER_MINUTE=50

# Fathom filters (applied as defaults, CLI flags override)
# RECORDED_BY=alice@example.com,bob@example.com
# TITLE_FILTER=Strategy,Alliances
# TITLE_EXCLUDE=Interview,1:1

# ── Google Meet ─────────────────────────────────────────────────────────
# Path to OAuth client_secret.json downloaded from Google Cloud Console
GOOGLE_CLIENT_SECRET=credentials/client_secret.json

# Where to save the OAuth token (auto-created on first auth)
GOOGLE_TOKEN_PATH=~/.gmeet-to-llmwiki/token.json

# Optional Google Meet overrides
# GMEET_OUTPUT_SUBDIR=Google Meet Transcripts
# GMEET_STATE_FILE=.gmeet-export-state.json
